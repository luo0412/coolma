# msvs_version=2022
# Forces electron/rebuild to use gcc/g++ instead of clang on Linux and msvc on Windows
# clang=0

# registry=https://registry.npmmirror.com/
registry=http://mirrors.cloud.tencent.com/npm/
# electron_mirror=https://registry.npmjs.org/electron/
# electron_mirror=https://npmmirror.com/mirrors/electron/
electron_mirror=https://mirrors.huaweicloud.com/electron/
# electron_mirror=http://mirrors.cloud.tencent.com/npm/electron/
# electron_mirror=http://mirrors.ustc.edu.cn/electron/
electron_custom_dir={{ version }}
electron_builder_binaries_mirror=https://npmmirror.com/mirrors/electron-builder-binaries/

sqlite3_binary_host_mirror=https://npmmirror.com/mirrors/sqlite3/
# sass_binary_site=https://npmmirror.com/mirrors/node-sass/

chromedriver_cdnurl=https://npmmirror.com/mirrors/chromedriver/
operadriver_cdnurl=https://npmmirror.com/mirrors/operadriver/
fse_binary_host_mirror=https://npmmirror.com/mirrors/fsevents/

# Production-only install: skips devDependencies to reduce package size
# Used by: npm install --omit=dev (or: npm ci --omit=dev)
only=production
omit=dev
